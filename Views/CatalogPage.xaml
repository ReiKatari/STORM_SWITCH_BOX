<Page
    x:Class="StormSwitchBox.Views.CatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:StormSwitchBox.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                <Button x:Name="BrowseButton" Style="{StaticResource AccentButtonStyle}" Height="40" Padding="16,0" CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE838;" FontSize="16"/>
                        <TextBlock Text="Папки сканирования" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.Flyout>
                        <Flyout>
                            <StackPanel Spacing="10" Width="300">
                                <TextBlock Text="Папки для сканирования" FontWeight="SemiBold"/>
                                <ListView x:Name="FoldersListView" Height="150" Background="#1A1A1A" CornerRadius="4" SelectionMode="Single"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <Button Content="Добавить" Click="AddFolder_Click">
                                        <Button.ContentTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xE710;" FontSize="14" Foreground="#4CAF50"/><TextBlock Text="Добавить"/></StackPanel>
                                            </DataTemplate>
                                        </Button.ContentTemplate>
                                    </Button>
                                    <Button Content="Удалить" Click="RemoveFolder_Click">
                                        <Button.ContentTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#F44336"/><TextBlock Text="Удалить"/></StackPanel>
                                            </DataTemplate>
                                        </Button.ContentTemplate>
                                    </Button>
                                </StackPanel>
                                <Button Content="Сканировать все" Click="ScanAllFolders_Click" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Grid VerticalAlignment="Center" Height="40">
                    <TextBox x:Name="SearchBox" PlaceholderText="Поиск по названию или Title ID..." Width="320" TextChanged="SearchBox_TextChanged" CornerRadius="8" Padding="36,8,8,8" Height="40"/>
                    <FontIcon Glyph="&#xE721;" FontSize="14" Foreground="Gray" HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="UpdateDbButton" Click="UpdateDbButton_Click" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Обновить базу данных TitleDB">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon x:Name="UpdateDbIcon" Glyph="&#xE895;" FontSize="16" Foreground="#00BCD4"/>
                        <TextBlock x:Name="UpdateDbTextBlock" Text="Обновление данных TitleDB" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock x:Name="ScanStatusText" Text="" Foreground="LightGray" VerticalAlignment="Center" FontSize="12"/>
                <ProgressRing x:Name="ScanProgress" IsActive="False" Width="20" Height="20" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Catalog Grid -->
        <GridView Grid.Row="1" x:Name="CatalogGridView" 
                  SelectionMode="None" 
                  IsItemClickEnabled="True"
                  ItemClick="CatalogGridView_ItemClick"
                  ShowsScrollingPlaceholders="True"
                  ItemContainerTransitions="{x:Null}">
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="12"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="CornerRadius" Value="12"/>
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:CatalogItem">
                    <Grid Width="240" Height="440" CornerRadius="12" 
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                          BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" 
                          BorderThickness="1" 
                          Padding="16"
                          PointerEntered="Grid_PointerEntered"
                          PointerExited="Grid_PointerExited"
                          RenderTransformOrigin="0.5,0.5">
                        
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="220"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Image Container -->
                        <Border Grid.Row="0" CornerRadius="8" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorFlyoutBrush}" BorderThickness="1">
                            <Grid>
                                <FontIcon Glyph="&#xE8B9;" FontSize="48" Foreground="{ThemeResource TextFillColorDisabledBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                <ProgressRing IsActive="{Binding IsLoading}" Width="32" Height="32" Foreground="Cyan" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <FontIcon Glyph="&#xEA39;" FontSize="32" Foreground="Crimson" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding HasError}" ToolTipService.ToolTip="{Binding ErrorMessage}"/>
                                
                                <!-- Update Indicator -->
                                <Border Background="Crimson" CornerRadius="12" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Visibility="{Binding OutdatedVisibility, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE895;" FontSize="10" Foreground="White"/>
                                        <TextBlock Text="Версия" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                        
                        <!-- Info Section -->
                        <StackPanel Grid.Row="1" Margin="0,12,0,0" Spacing="4">
                            <TextBlock Text="{Binding TitleName}" FontWeight="Bold" FontSize="15" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" ToolTipService.ToolTip="{Binding TitleName}"/>
                            <TextBlock Text="{Binding Publisher}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                            
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                    <Button Background="#1A5C8A" CornerRadius="4" Padding="6,2" BorderThickness="0" Click="CardCopyVersion_Click" ToolTipService.ToolTip="Копировать версию">
                                        <TextBlock Text="{Binding Version}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                    </Button>
                                    <Button Background="#2980B9" CornerRadius="4" Padding="6,2" BorderThickness="0" Click="CardCopyVersionCode_Click" ToolTipService.ToolTip="Копировать код версии">
                                        <TextBlock Text="{Binding VersionCode}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                    </Button>
                                </StackPanel>

                                <Button Grid.Column="1" Background="#8E44AD" CornerRadius="4" Padding="6,2" BorderThickness="0" Click="CardCopyReleaseDate_Click" ToolTipService.ToolTip="Копировать дату выхода" HorizontalAlignment="Right" Visibility="{Binding ReleaseDateVisibility}">
                                    <TextBlock Text="{Binding ReleaseDate}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                </Button>
                            </Grid>
                            
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                <Button Background="#333333" CornerRadius="4" Padding="6,2" BorderThickness="0" Click="CardCopyTitleId_Click" ToolTipService.ToolTip="Копировать Title ID">
                                    <TextBlock Text="{Binding TitleId}" FontSize="11" Foreground="White" FontFamily="Consolas"/>
                                </Button>
                            </StackPanel>

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0" Background="#4CAF50" CornerRadius="4" Padding="6,2" Visibility="{Binding RegionsVisibility}" Margin="0,0,6,0">
                                    <TextBlock Text="{Binding Regions}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                                <Button Grid.Column="1" Background="#E91E63" CornerRadius="4" Padding="6,2" BorderThickness="0">
                                    <Button.Flyout>
                                        <Flyout>
                                            <StackPanel Width="350">
                                                <TextBlock Text="Список дополнений" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <ListView ItemsSource="{Binding DlcList}" MaxHeight="400" SelectionMode="Single">
                                                    <ListView.ItemContainerTransitions>
                                                        <TransitionCollection>
                                                            <EntranceThemeTransition IsStaggeringEnabled="True"/>
                                                        </TransitionCollection>
                                                    </ListView.ItemContainerTransitions>
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Padding="0,4">
                                                                <TextBlock Text="{Binding Name}" TextWrapping="Wrap" FontSize="13" IsTextSelectionEnabled="True"/>
                                                                <TextBlock Text="{Binding Id}" FontSize="11" Foreground="Gray" IsTextSelectionEnabled="True"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                    <TextBlock Text="{Binding DlcCountDisplay}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                </Button>
                                <Button Grid.Column="2" Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" CornerRadius="4" Padding="6,2" Click="CardCopySize_Click" ToolTipService.ToolTip="Копировать размер" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding FileSize}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                                </Button>
                            </Grid>

                            <Grid Margin="0,4,0,0" Visibility="{Binding OutdatedVisibility, Mode=OneWay}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Background="Crimson" CornerRadius="4" Padding="6,2" BorderThickness="0" Click="CardCopyUpdateVersion_Click" ToolTipService.ToolTip="Копировать актуальную версию">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding UpdateVersion}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding UpdateVersionCode}" FontSize="11" Foreground="WhiteSmoke" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" HorizontalAlignment="Right" Background="Transparent" BorderBrush="Crimson" BorderThickness="1" CornerRadius="4" Padding="4,2" Click="AcceptUpdate_Click" ToolTipService.ToolTip="Принять обновление (убирает ложную плашку)" Visibility="{Binding AcceptButtonVisibility, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE8FB;" FontSize="10" Foreground="Crimson"/>
                                        <TextBlock Text="ПРИМЕНИТЬ ВЕРСИЮ" FontSize="10" Foreground="Crimson" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
        
        <!-- Details Overlay -->
        <Grid x:Name="DetailsOverlay" Grid.RowSpan="2" Background="#99000000" Visibility="Collapsed" PointerPressed="DetailsOverlay_PointerPressed">
            <Border Width="850" Height="650" CornerRadius="16" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" PointerPressed="DetailsContent_PointerPressed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Grid Grid.Row="0" Padding="24,24,24,0">
                        <TextBlock x:Name="DetailTitle" Text="Game Title" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" MaxWidth="700" HorizontalAlignment="Left"/>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Click="CloseDetails_Click">
                            <FontIcon Glyph="&#xE711;" FontSize="16"/>
                        </Button>
                    </Grid>
                    
                    <ScrollViewer Grid.Row="1" Padding="24" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Left: Cover & Basic Info -->
                            <StackPanel Grid.Column="0" Spacing="16">
                                <Border CornerRadius="12" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorFlyoutBrush}" BorderThickness="1">
                                    <Image x:Name="DetailCover" Stretch="UniformToFill" Width="250" Height="250"/>
                                </Border>
                                <Button x:Name="SaveCoverButton" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Click="SaveCoverButton_Click">
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE886;" FontSize="14"/>
                                                <TextBlock Text="Сохранить обложку (PNG)" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Издатель:" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="DetailPublisher" Text="Publisher" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </StackPanel>
                                
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Разработчик:" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="DetailDeveloper" Text="Developer" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </StackPanel>
                                
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Жанр:" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="DetailCategory" Text="Category" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </StackPanel>
                                
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Дата выхода:" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="DetailReleaseDate" Text="Release Date" FontSize="15" FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Отображаемая версия:" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock x:Name="DetailDisplayVersion" Text="1.0" FontSize="15" FontWeight="SemiBold" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" ToolTipService.ToolTip="Копировать" Click="CopyDisplayVersion_Click">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="12"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                                
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Версия:" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock x:Name="DetailVersionCode" Text="0" FontSize="15" FontWeight="SemiBold" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" ToolTipService.ToolTip="Копировать" Click="CopyVersionCode_Click">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="12"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                                
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Title ID:" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock x:Name="DetailTitleId" Text="0000000000000000" FontSize="15" FontWeight="SemiBold" FontFamily="Consolas" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" ToolTipService.ToolTip="Копировать" Click="CopyTitleId_Click">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="12"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Регион:" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="DetailRegions" Text="N/A" FontSize="15" FontWeight="SemiBold"/>
                                </StackPanel>
                                
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Количество дополнений:" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="DetailDlcCount" Text="0" FontSize="15" FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="Размер файла:" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="DetailSize" Text="0 MB" FontSize="15" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- Right: Extended Info & Media -->
                            <StackPanel Grid.Column="2" Spacing="24">
                                
                                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="16">
                                    <Grid ColumnSpacing="16" RowSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                            <TextBlock Text="Возрастной рейтинг:" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock x:Name="DetailRating" Text="PEGI 18+" FontSize="14" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Видеозахват:" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock x:Name="DetailVideoCap" Text="Да" FontSize="14" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                            <TextBlock Text="Размер сохранений:" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock x:Name="DetailSaveSize" Text="64 MB" FontSize="14" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Поддерживаемые языки:" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock x:Name="DetailLangs" Text="Russian, English" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="DetailIntro" Text="" FontSize="16" FontStyle="Italic" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Описание:" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="DetailDescription" Text="Нет описания" FontSize="14" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>

                                <StackPanel x:Name="ScreenshotsPanel" Spacing="12">
                                    <TextBlock Text="Скриншоты и изображения:" FontSize="18" FontWeight="SemiBold"/>
                                    <GridView x:Name="ScreenshotsGridView" SelectionMode="None" IsItemClickEnabled="True" ItemClick="ScreenshotsGridView_ItemClick">
                                        <GridView.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="8" Margin="0,0,12,12" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1">
                                                    <Image Source="{Binding}" Width="200" Height="112" Stretch="UniformToFill"/>
                                                </Border>
                                            </DataTemplate>
                                        </GridView.ItemTemplate>
                                    </GridView>
                                </StackPanel>
                                
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Fullscreen Screenshot Overlay -->
        <Grid x:Name="FullscreenImageOverlay" Grid.RowSpan="2" Background="#DD000000" Visibility="Collapsed" PointerPressed="FullscreenImageOverlay_PointerPressed">
            <Image x:Name="FullscreenImage" Stretch="Uniform" Margin="48"/>
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="24" Background="Transparent" BorderThickness="0" Click="CloseFullscreen_Click">
                <FontIcon Glyph="&#xE711;" FontSize="24" Foreground="White"/>
            </Button>
        </Grid>
    </Grid>
</Page>
