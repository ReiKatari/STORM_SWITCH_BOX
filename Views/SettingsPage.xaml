<Page
    x:Class="StormSwitchBox.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="32" HorizontalAlignment="Stretch">
            
            <TextBlock Text="Параметры" Style="{StaticResource TitleTextBlockStyle}" FontWeight="SemiBold" />

            <!-- Карточка: Системные файлы -->
            <StackPanel Spacing="12">
                <TextBlock Text="Системные файлы" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Файл криптографических ключей (prod.keys / keys.txt)" VerticalAlignment="Center"/>
                                <TextBlock Text="Загружать ключи для расшифровки форматов Nintendo Switch" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Visibility="{x:Bind KeysSelectedVisibility, Mode=OneTime}">
                                    <FontIcon Glyph="&#xE73E;" Foreground="LimeGreen" FontSize="14"/>
                                    <TextBlock Text="Файл выбран" Foreground="LimeGreen" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBox x:Name="VerBox1" Width="40" Height="40" MaxLength="1" FontSize="16" FontWeight="Bold" Padding="0,6,0,0" TextAlignment="Center" KeyDown="VerBox_KeyDown" TextChanged="VerBox_TextChanged"/>
                                    <TextBox x:Name="VerBox2" Width="40" Height="40" MaxLength="1" FontSize="16" FontWeight="Bold" Padding="0,6,0,0" TextAlignment="Center" KeyDown="VerBox_KeyDown" TextChanged="VerBox_TextChanged"/>
                                    <TextBox x:Name="VerBox3" Width="40" Height="40" IsReadOnly="True" Text="." FontSize="16" FontWeight="Bold" Padding="0,6,0,0" TextAlignment="Center" IsTabStop="False" Background="Transparent" BorderThickness="1"/>
                                    <TextBox x:Name="VerBox4" Width="40" Height="40" MaxLength="1" FontSize="16" FontWeight="Bold" Padding="0,6,0,0" TextAlignment="Center" KeyDown="VerBox_KeyDown" TextChanged="VerBox_TextChanged"/>
                                    <TextBox x:Name="VerBox5" Width="40" Height="40" IsReadOnly="True" Text="." FontSize="16" FontWeight="Bold" Padding="0,6,0,0" TextAlignment="Center" IsTabStop="False" Background="Transparent" BorderThickness="1"/>
                                    <TextBox x:Name="VerBox6" Width="40" Height="40" MaxLength="1" FontSize="16" FontWeight="Bold" Padding="0,6,0,0" TextAlignment="Center" KeyDown="VerBox_KeyDown" TextChanged="VerBox_TextChanged"/>
                                </StackPanel>
                                <Button Content="Выбрать файл..." Click="SelectKeysButton_Click" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Карточка: Выходная папка -->
            <StackPanel Spacing="12">
                <TextBlock Text="Выходные параметры" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Выходная папка по умолчанию" VerticalAlignment="Center"/>
                            <TextBlock Text="Общая папка для сохранения обработанных файлов (можно изменить в каждой задаче)" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OutputFolderBox" HorizontalAlignment="Stretch" Margin="0,0,12,0" PlaceholderText="Не указана" 
                                     Text="{x:Bind Settings.OutputFolder, Mode=TwoWay}" IsReadOnly="True" VerticalAlignment="Center"
                                     AllowDrop="True" DragOver="OutputFolderBox_DragOver" Drop="OutputFolderBox_Drop"/>
                            <Button Grid.Column="1" Content="Обзор..." Click="SelectOutputFolder_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Карточка: Параметры обработки -->
            <StackPanel Spacing="12">
                <TextBlock Text="Параметры сжатия и сборки" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="20">
                        <Grid>
                            <TextBlock Text="Уровень сжатия" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CompressionCombo" HorizontalAlignment="Right" Width="200" SelectionChanged="CompressionCombo_Changed">
                                <ComboBoxItem Content="Быстрое (уровень 3)" Tag="3"/>
                                <ComboBoxItem Content="Баланс (уровень 10)" Tag="10"/>
                                <ComboBoxItem Content="Стандарт (уровень 18)" Tag="18"/>
                                <ComboBoxItem Content="Ультра (уровень 22)" Tag="22"/>
                            </ComboBox>
                        </Grid>

                        <Grid>
                            <TextBlock Text="Понижение версии (KeyGen) в Мульти-контенте / XCI" VerticalAlignment="Center"/>
                            <NumberBox HorizontalAlignment="Right" Width="200" Value="{x:Bind Settings.KeyGeneration, Mode=TwoWay}" Minimum="0" Maximum="30" SpinButtonPlacementMode="Inline" ValueChanged="Setting_ValueChanged"/>
                        </Grid>

                        <Grid>
                            <TextBlock Text="Одновременные задачи" VerticalAlignment="Center"/>
                            <NumberBox HorizontalAlignment="Right" Width="200" Value="{x:Bind Settings.ConcurrentTasks, Mode=TwoWay}" Minimum="1" Maximum="5" SpinButtonPlacementMode="Inline" ValueChanged="Setting_ValueChanged"/>
                        </Grid>
                        
                        <Grid>
                            <TextBlock Text="Многопоточность (Используемые ядра)" VerticalAlignment="Center"/>
                            <NumberBox HorizontalAlignment="Right" Width="200" Value="{x:Bind Settings.UsedCores, Mode=TwoWay}" Minimum="1" Maximum="{x:Bind MaxCores, Mode=OneTime}" SpinButtonPlacementMode="Inline" ValueChanged="Setting_ValueChanged"/>
                        </Grid>

                        <Grid>
                            <TextBlock Text="Удалять исходные файлы после успеха" VerticalAlignment="Center"/>
                            <ToggleSwitch HorizontalAlignment="Right" IsOn="{x:Bind Settings.DeleteSourceOnSuccess, Mode=TwoWay}" Toggled="Toggle_Changed"/>
                        </Grid>

                        <StackPanel Spacing="12">
                            <Grid>
                                <TextBlock Text="Удалять неиспользуемые языки" VerticalAlignment="Center"/>
                                <ToggleSwitch x:Name="TrimXciToggle" HorizontalAlignment="Right" IsOn="{x:Bind Settings.TrimXci, Mode=TwoWay}" Toggled="Toggle_Changed"/>
                            </Grid>
                            
                            <!-- Выбор языков -->
                            <Border x:Name="LanguageSelectionPanel" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="4" Padding="12"
                                    Visibility="{x:Bind TrimXciToggle.IsOn, Mode=OneWay}">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Выберите языки, которые нужно ОСТАВИТЬ при вырезании:" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <ItemsControl x:Name="LanguageItemsControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="150" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid>
                            <TextBlock Text="Комплексное выходное имя файла по папкам" VerticalAlignment="Center"/>
                            <ToggleSwitch HorizontalAlignment="Right" IsOn="{x:Bind Settings.ComplexFolders, Mode=TwoWay}" Toggled="Toggle_Changed"/>
                        </Grid>

                        <Grid>
                            <TextBlock Text="Пересборка файлов в Мульти-контенте" VerticalAlignment="Center"/>
                            <ToggleSwitch HorizontalAlignment="Right" IsOn="{x:Bind Settings.ForceMultiRebuild, Mode=TwoWay}" Toggled="Toggle_Changed"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Карточка: О программе -->
            <StackPanel Spacing="12">
                <TextBlock Text="О программе" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="100" Height="100" CornerRadius="12" Background="{ThemeResource SystemAccentColor}" Margin="0,0,24,0" VerticalAlignment="Top">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="STORM" FontWeight="Black" FontSize="20" HorizontalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="BOX" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="STORM SWITCH BOX 3.8.8" FontWeight="Bold" FontSize="24"/>

                            </StackPanel>
                            <TextBlock Text="Нативная версия WinUI 3" Foreground="{ThemeResource SystemAccentColor}" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Специализированный комбайн для обработки, сжатия и конвертации игр Nintendo Switch. Интеграция нативных алгоритмов (LibHac + ZstdSharp) для максимальной производительности." 
                                       TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0" LineHeight="22"/>
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,20,0,0">
                                <Button Content="Проверить обновления" Style="{StaticResource AccentButtonStyle}" Padding="16,8" Click="CheckUpdatesButton_Click" x:Name="CheckUpdatesButton"/>
                                <ProgressRing x:Name="UpdateProgressRing" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" Visibility="Collapsed"/>
                                <Button Content="Открыть папку с логами" Padding="16,8" Click="OpenLogsFolder_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
            
        </StackPanel>
    </ScrollViewer>
</Page>
