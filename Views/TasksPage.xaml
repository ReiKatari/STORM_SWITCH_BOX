<Page
    x:Class="StormSwitchBox.Views.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:StormSwitchBox.Views"
    xmlns:models="using:StormSwitchBox.Models"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="LogListItem" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Margin" Value="0,-2,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style x:Key="CenterAlignedCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Padding="20" AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop" DragLeave="Grid_DragLeave" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition x:Name="LogRow" Height="130"/>
        </Grid.RowDefinitions>
        
        <!-- ========== ТУЛБАР ========== -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left" Background="Transparent" Margin="0,0,0,6">
            <AppBarButton Label="Добавить">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE896;" Foreground="#2ECC71"/>
                </AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Добавить файлы..." Click="AddFiles_Click"/>
                        <MenuFlyoutItem Text="Добавить папку..." Click="AddFolder_Click"/>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarElementContainer VerticalAlignment="Center" Margin="16,0">
                <ComboBox x:Name="FormatComboBox" SelectedIndex="{x:Bind ViewModel.SelectedFormatIndex, Mode=TwoWay}" Width="100" SelectionChanged="FormatComboBox_SelectionChanged">
                    <ComboBoxItem Content="NSP"/>
                    <ComboBoxItem Content="NSZ"/>
                    <ComboBoxItem Content="XCI"/>
                    <ComboBoxItem Content="XCZ"/>
                </ComboBox>
            </AppBarElementContainer>
            <AppBarButton Label="Запустить всё" Command="{x:Bind ViewModel.StartAllTasksCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE768;" Foreground="#00E5FF"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Остановить" Command="{x:Bind ViewModel.StopAllTasksCommand}" IsEnabled="{x:Bind ViewModel.IsAnyTaskRunning, Mode=OneWay}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE73B;" Foreground="#FFC107"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Свернуть все" Click="CollapseAll_Click" ToolTipService.ToolTip="Закрыть детальную информацию у всех задач">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8A0;" Foreground="#B388FF"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Столбцы">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8B3;" Foreground="#536DFE"/>
                </AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <Flyout>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Отображение столбцов" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <CheckBox Content="Обработка" IsChecked="True" Checked="ColumnVisibility_Checked" Unchecked="ColumnVisibility_Unchecked" Tag="2"/>
                            <CheckBox Content="Нач. формат" IsChecked="True" Checked="ColumnVisibility_Checked" Unchecked="ColumnVisibility_Unchecked" Tag="3"/>
                            <CheckBox Content="Кон. формат" IsChecked="True" Checked="ColumnVisibility_Checked" Unchecked="ColumnVisibility_Unchecked" Tag="4"/>
                            <CheckBox Content="Нач. размер" IsChecked="True" Checked="ColumnVisibility_Checked" Unchecked="ColumnVisibility_Unchecked" Tag="5"/>
                            <CheckBox Content="Кон. размер" IsChecked="True" Checked="ColumnVisibility_Checked" Unchecked="ColumnVisibility_Unchecked" Tag="6"/>
                            <CheckBox Content="Разница" IsChecked="True" Checked="ColumnVisibility_Checked" Unchecked="ColumnVisibility_Unchecked" Tag="7"/>
                            <CheckBox Content="Сжатие" IsChecked="True" Checked="ColumnVisibility_Checked" Unchecked="ColumnVisibility_Unchecked" Tag="8"/>
                            <CheckBox Content="Файлы" IsChecked="True" Checked="ColumnVisibility_Checked" Unchecked="ColumnVisibility_Unchecked" Tag="9"/>
                            <CheckBox Content="RomFS" IsChecked="True" Checked="ColumnVisibility_Checked" Unchecked="ColumnVisibility_Unchecked" Tag="10"/>
                            <CheckBox Content="ExeFS" IsChecked="True" Checked="ColumnVisibility_Checked" Unchecked="ColumnVisibility_Unchecked" Tag="11"/>
                        </StackPanel>
                    </Flyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="Очистить" Command="{x:Bind ViewModel.ClearTasksCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE74D;" Foreground="#FF5252"/>
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- ========== ТАБЛИЦА ЗАДАЧ ========== -->
        <Grid Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
            <Grid.Resources>
                <SolidColorBrush x:Key="DataGridRowSelectedUnfocusedBackgroundBrush" Color="#20FFFFFF"/>
                <SolidColorBrush x:Key="DataGridRowSelectedHoveredUnfocusedBackgroundBrush" Color="#25FFFFFF"/>
                <SolidColorBrush x:Key="DataGridRowSelectedHoveredBackgroundBrush" Color="#30FFFFFF"/>
                <SolidColorBrush x:Key="DataGridRowSelectedBackgroundBrush" Color="#30FFFFFF"/>
            </Grid.Resources>
            
            <controls:DataGrid x:Name="TasksGrid" ItemsSource="{x:Bind ViewModel.Tasks}"
                               AutoGenerateColumns="False"
                               GridLinesVisibility="All"
                               HeadersVisibility="Column"
                               RowDetailsVisibilityMode="Collapsed"
                               SelectionMode="Single"
                               Background="Transparent"
                               CanUserSortColumns="False"
                               CanUserReorderColumns="False"
                               RowHeight="88"
                               HorizontalScrollBarVisibility="Auto"
                               Tapped="DataGrid_Tapped"
                               PointerPressed="TasksGrid_PointerPressed"
                               SelectionChanged="TasksGrid_SelectionChanged">

                <controls:DataGrid.ColumnHeaderStyle>
                    <Style TargetType="primitives:DataGridColumnHeader">
                        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}"/>
                        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="8,10"/>
                        <Setter Property="ContentTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </controls:DataGrid.ColumnHeaderStyle>
                
                <controls:DataGrid.Columns>
                    <controls:DataGridTemplateColumn Header="Иконка" Width="100" MinWidth="80" IsReadOnly="True">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="models:ProcessingTask">
                                <Image Source="{x:Bind GameIcon, Mode=OneWay}" Width="76" Height="76" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,2"/>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>
                    
                    <controls:DataGridTemplateColumn Header="Задача" Width="375" MinWidth="150" IsReadOnly="True">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding OutputFileName}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="12,0,12,0"/>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>
                    
                    <controls:DataGridTextColumn Header="Обработка" Binding="{Binding OperationDisplay}" IsReadOnly="True" Width="180" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                    
                    <controls:DataGridTextColumn Header="Нач. формат" Binding="{Binding SourceFormat}" IsReadOnly="True" Width="130" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                    
                    <controls:DataGridTemplateColumn Header="Кон. формат" Width="130" MinWidth="50">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox SelectedItem="{Binding TargetFormat, Mode=TwoWay}" IsEnabled="{Binding IsNotRunning, Mode=OneWay}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                          Foreground="Cyan" Padding="4,0" MinWidth="55" MinHeight="24" Height="24" BorderThickness="0" Background="Transparent">
                                    <x:String>NSP</x:String>
                                    <x:String>NSZ</x:String>
                                    <x:String>XCI</x:String>
                                    <x:String>XCZ</x:String>
                                </ComboBox>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                    <controls:DataGridTextColumn Header="Нач. размер" Binding="{Binding SourceSize}" IsReadOnly="True" Width="130" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                    <controls:DataGridTextColumn Header="Кон. размер" Binding="{Binding TargetSize}" IsReadOnly="True" Width="130" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                    <controls:DataGridTextColumn Header="Разница" Binding="{Binding SizeDifference}" IsReadOnly="True" Width="180" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                    <controls:DataGridTextColumn Header="Сжатие" Binding="{Binding CompressionLevel}" IsReadOnly="True" Width="110" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                    
                    <controls:DataGridTemplateColumn Header="Файлы" Width="110" MinWidth="50">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding FilesCount}" 
                                        VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Padding="6,2" MinHeight="0" MinWidth="0"
                                        Background="Transparent" BorderThickness="0"
                                        ToolTipService.ToolTip="Показать список файлов"
                                        Click="FilesCount_Click" Tag="{Binding}"/>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                    <controls:DataGridTextColumn Header="RomFS" Binding="{Binding HasRomFs}" IsReadOnly="True" Width="110" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                    <controls:DataGridTextColumn Header="ExeFS" Binding="{Binding HasExeFs}" IsReadOnly="True" Width="110" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>

                    <controls:DataGridTemplateColumn Header="Статус" Width="150" MinWidth="50">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6" VerticalAlignment="Center" Margin="4,0">
                                    <ProgressRing IsActive="{Binding IsRunning}" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <Border Background="{Binding StatusColor}" CornerRadius="6" Padding="12,4">
                                        <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                    <controls:DataGridTemplateColumn Header="Выполнение" Width="160" MinWidth="50">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="8,0" VerticalAlignment="Center">
                                    <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100" VerticalAlignment="Center" Foreground="{Binding StatusColor}" Height="6" CornerRadius="3"/>
                                    <TextBlock Text="{Binding Speed}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-16,4,0" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontWeight="SemiBold"/>
                                </Grid>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                    <controls:DataGridTemplateColumn Width="45" MinWidth="40">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Click="DeleteTask_Click" Tag="{Binding}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Padding="4,2" MinHeight="0" MinWidth="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Удалить задачу">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="IndianRed"/>
                                </Button>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>
                </controls:DataGrid.Columns>
            </controls:DataGrid>

            <!-- ========== ТАБЛИЦА ВЕРИФИКАЦИИ (РАЗДЕЛ ПРОВЕРКА) ========== -->
            <controls:DataGrid x:Name="VerifyGrid"
                               AutoGenerateColumns="False"
                               GridLinesVisibility="All"
                               HeadersVisibility="Column"
                               RowDetailsVisibilityMode="Collapsed"
                               SelectionMode="Single"
                               Background="Transparent"
                               CanUserSortColumns="False"
                               CanUserReorderColumns="False"
                               RowHeight="88"
                               HorizontalScrollBarVisibility="Auto"
                               Tapped="DataGrid_Tapped"
                               PointerPressed="TasksGrid_PointerPressed"
                               SelectionChanged="TasksGrid_SelectionChanged"
                               Visibility="Collapsed">

                <controls:DataGrid.ColumnHeaderStyle>
                    <Style TargetType="primitives:DataGridColumnHeader">
                        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}"/>
                        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="8,10"/>
                    </Style>
                </controls:DataGrid.ColumnHeaderStyle>

                <controls:DataGrid.Columns>
                    <controls:DataGridTemplateColumn Header="Иконка" Width="80" MinWidth="60" IsReadOnly="True">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="models:ProcessingTask">
                                <Image Source="{x:Bind GameIcon, Mode=OneWay}" Width="64" Height="64" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,2"/>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                    <controls:DataGridTemplateColumn Header="Файл" Width="260" MinWidth="150" IsReadOnly="True">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding OutputFileName}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="12,0,12,0"/>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                    <controls:DataGridTextColumn Header="Размер" Binding="{Binding SourceSize}" IsReadOnly="True" Width="120" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                    <controls:DataGridTextColumn Header="Тип контента" Binding="{Binding VerifyType}" IsReadOnly="True" Width="130" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                    <controls:DataGridTextColumn Header="Title ID" Binding="{Binding VerifyTitleId}" IsReadOnly="True" Width="150" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                    <controls:DataGridTextColumn Header="Версия" Binding="{Binding VerifyVersion}" IsReadOnly="True" Width="90" MinWidth="40" ElementStyle="{StaticResource CenterAlignedCell}"/>
                    <controls:DataGridTextColumn Header="Структура" Binding="{Binding VerifyStructure}" IsReadOnly="True" Width="200" MinWidth="100" ElementStyle="{StaticResource CenterAlignedCell}"/>
                    <controls:DataGridTextColumn Header="Сшит правильно" Binding="{Binding VerifyMergedStatus}" IsReadOnly="True" Width="150" MinWidth="80" ElementStyle="{StaticResource CenterAlignedCell}"/>

                    <controls:DataGridTemplateColumn Header="Статус" Width="150" MinWidth="50">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6" VerticalAlignment="Center" Margin="4,0">
                                    <ProgressRing IsActive="{Binding IsRunning}" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <Border Background="{Binding StatusColor}" CornerRadius="6" Padding="12,4">
                                        <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                    <controls:DataGridTemplateColumn Header="Выполнение" Width="160" MinWidth="50">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="8,0" VerticalAlignment="Center">
                                    <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100" VerticalAlignment="Center" Foreground="{Binding StatusColor}" Height="6" CornerRadius="3"/>
                                </Grid>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                    <controls:DataGridTemplateColumn Width="45" MinWidth="40">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Click="DeleteTask_Click" Tag="{Binding}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Padding="4,2" MinHeight="0" MinWidth="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Удалить задачу">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="IndianRed"/>
                                </Button>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>
                </controls:DataGrid.Columns>
            </controls:DataGrid>
        </Grid>

        <Thumb x:Name="LogResizerThumb" Grid.Row="2" Height="16" HorizontalAlignment="Stretch" Margin="0,-2"
               DragDelta="LogResizer_DragDelta" DragCompleted="LogResizer_DragCompleted"
               PointerEntered="LogResizerThumb_PointerEntered" PointerExited="LogResizerThumb_PointerExited"
               ToolTipService.ToolTip="Потяните вверх или вниз, чтобы изменить размер журнала">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Grid Background="#01000000"> <!-- Almost transparent to ensure hit testing -->
                        <Border Height="4" Width="40" Background="{ThemeResource SystemControlBackgroundBaseMediumBrush}" CornerRadius="2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Rectangle Fill="{ThemeResource CardStrokeColorDefaultBrush}" Height="1" VerticalAlignment="Top"/>
                    </Grid>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <!-- ========== ПАНЕЛЬ ДЕТАЛЕЙ И ЛОГОВ (Tabbed Pivot) ========== -->
        <Border Grid.Row="3" Margin="0,4,0,0" Background="#1A1A1A" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <Pivot x:Name="DetailsPivot" Padding="0">
                <!-- Вкладка 1: Журнал событий -->
                <PivotItem Header="Журнал событий">
                    <Grid Padding="12,4,12,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                          <Grid Grid.Row="0" Margin="0,4,0,6">
                              <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                                  <FontIcon Glyph="&#xE756;" FontSize="14" Foreground="DarkGray" VerticalAlignment="Center"/>
                                  <TextBlock Text="ПОЛНЫЙ ЖУРНАЛ СОБЫТИЙ ПРОГРАММЫ" FontWeight="Bold" FontSize="10" Foreground="DarkGray" VerticalAlignment="Center" CharacterSpacing="100"/>
                              </StackPanel>
                              <Button Content="Копировать всё" Click="CopyLogs_Click" HorizontalAlignment="Right" Padding="8,4" FontSize="12" CornerRadius="4" ToolTipService.ToolTip="Скопировать все логи в буфер обмена"/>
                          </Grid>
                        <ListView x:Name="LogsListView" Grid.Row="1" ItemsSource="{x:Bind AppLogs}" SelectionMode="None"
                                  ItemContainerStyle="{StaticResource LogListItem}">
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView" />
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:LogMessage">
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind FormattedTime}" Foreground="#666666" FontFamily="Consolas" FontSize="11" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Message}" Foreground="{x:Bind ColorBrush}" FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" IsTextSelectionEnabled="True"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </PivotItem>
                
                <!-- Вкладка 2: Детали и лог задачи -->
                <PivotItem Header="Параметры и Лог выбранной задачи">
                    <Grid DataContext="{Binding ElementName=TasksGrid, Path=SelectedItem}" Padding="12,8">
                        <!-- Если ничего не выбрано, показываем плейсхолдер -->
                        <TextBlock x:Name="NoSelectionPlaceholder" 
                                   Text="Выберите задачу в таблице для просмотра её параметров и лога выполнения" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                                   Foreground="DarkGray" FontSize="12" FontStyle="Italic"/>
                        
                        <!-- Если задача выбрана, показываем детали -->
                        <Grid x:Name="DetailsContainer" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="ParamsColumn" Width="680"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Левая колонка: параметры -->
                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
                                <StackPanel Spacing="6" Padding="0,4,0,4">
                                    <Grid RowSpacing="6" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Входные файлы:" FontWeight="SemiBold" Foreground="LightSkyBlue" FontSize="11" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding InputFolders}" TextWrapping="Wrap" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="Gray"/>
                                        
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Выходная папка:" FontWeight="SemiBold" Foreground="LightSkyBlue" FontSize="11" VerticalAlignment="Center"/>
                                        <Grid Grid.Row="1" Grid.Column="1" ColumnSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding OutputFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                     FontSize="11" IsEnabled="{Binding IsNotRunning, Mode=OneWay}" Height="28" MinHeight="0" Padding="6,2"
                                                     VerticalContentAlignment="Center"
                                                     AllowDrop="True" DragOver="OutputFolder_DragOver" Drop="OutputFolder_Drop"
                                                     PlaceholderText="Путь или перетащите папку"/>
                                            <Button Grid.Column="1" Content="Обзор..." Click="BrowseOutputFolder_Click" Tag="{Binding}" FontSize="10" Padding="6,2" Height="28" IsEnabled="{Binding IsNotRunning, Mode=OneWay}"/>
                                        </Grid>
                                        
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Имя файла:" FontWeight="SemiBold" Foreground="LightSkyBlue" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding OutputFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="11" AllowDrop="True" DragOver="OutputName_DragOver" Drop="OutputName_Drop" Foreground="Cyan" Height="28" MinHeight="0" Padding="6,2" VerticalContentAlignment="Center" IsEnabled="{Binding IsNotRunning, Mode=OneWay}"/> 
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                            
                            <!-- Правая колонка: лог выполнения -->
                            <Grid Grid.Column="1" Background="#111111" CornerRadius="4" BorderBrush="#333333" BorderThickness="1" Margin="0,0,0,4">
                                <ScrollViewer x:Name="TaskLogScrollViewer" Padding="8,4" VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding LogDetails}" TextWrapping="Wrap" FontFamily="Consolas" Foreground="DarkCyan" FontSize="11" IsTextSelectionEnabled="True" SizeChanged="TaskLogTextBlock_SizeChanged"/>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Grid>
                </PivotItem>
            </Pivot>
        </Border>
        
        <!-- Оверлей при перетаскивании -->
        <Border x:Name="DropOverlay" Background="#80000000" CornerRadius="8" Visibility="Collapsed" Grid.RowSpan="4">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <FontIcon Glyph="&#xE8B5;" FontSize="64" Foreground="White"/>
                <TextBlock Text="Отпустите файлы для добавления" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Оверлей при загрузке файлов -->
        <Border x:Name="LoadingOverlay" Background="#80000000" CornerRadius="8" Visibility="Collapsed" Grid.RowSpan="4">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="True" Width="64" Height="64" Foreground="LightSkyBlue"/>
