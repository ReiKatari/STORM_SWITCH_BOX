<Page
    x:Class="StormSwitchBox.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:StormSwitchBox.Models"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="CenterAlignedCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="20,0,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Panel -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="15" Margin="0,0,0,20">
            <Button Click="ClearHistory_Click" Style="{StaticResource AccentButtonStyle}" Background="#CC3333">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE74D;" Foreground="White"/>
                    <TextBlock Text="Очистить историю"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- History Grid -->
        <controls:DataGrid x:Name="HistoryGrid" Grid.Row="1" ItemsSource="{x:Bind HistoryTasks, Mode=OneWay}"
                           AutoGenerateColumns="False"
                           GridLinesVisibility="All"
                           HeadersVisibility="Column"
                           RowDetailsVisibilityMode="VisibleWhenSelected"
                           SelectionMode="Single"
                           Background="Transparent"
                           CanUserSortColumns="False"
                           CanUserReorderColumns="False"
                           RowHeight="88"
                           Tapped="HistoryGrid_Tapped"
                           PointerPressed="HistoryGrid_PointerPressed">

            <controls:DataGrid.ColumnHeaderStyle>
                <Style TargetType="primitives:DataGridColumnHeader">
                    <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}"/>
                    <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="8,10"/>
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </controls:DataGrid.ColumnHeaderStyle>

            <controls:DataGrid.RowStyle>
                <Style TargetType="controls:DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </controls:DataGrid.RowStyle>

            <controls:DataGrid.Columns>
                <controls:DataGridTemplateColumn Header="Иконка" Width="100" MinWidth="80" IsReadOnly="True">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding GameIcon}" Width="76" Height="76" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,2"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTextColumn Header="Время" Binding="{Binding FinishedAtDisplay}" IsReadOnly="True" Width="140" MinWidth="100"/>
                
                <controls:DataGridTemplateColumn Header="Задача" Width="200" MinWidth="50" IsReadOnly="True">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding OutputFileName}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="12,0,12,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTextColumn Header="Обработка" Binding="{Binding OperationDisplay}" IsReadOnly="True" Width="140" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                <controls:DataGridTextColumn Header="Нач. формат" Binding="{Binding SourceFormat}" IsReadOnly="True" Width="120" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                <controls:DataGridTemplateColumn Header="Кон. формат" Width="120" MinWidth="50">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:ProcessingTask">
                            <TextBlock Text="{x:Bind TargetFormat}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" Foreground="Cyan" FontWeight="SemiBold"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTextColumn Header="Нач. размер" Binding="{Binding SourceSize}" IsReadOnly="True" Width="110" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                <controls:DataGridTextColumn Header="Кон. размер" Binding="{Binding TargetSize}" IsReadOnly="True" Width="110" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                <controls:DataGridTextColumn Header="Разница" Binding="{Binding SizeDifference}" IsReadOnly="True" Width="160" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                <controls:DataGridTextColumn Header="Сжатие" Binding="{Binding CompressionLevel}" IsReadOnly="True" Width="90" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                <controls:DataGridTemplateColumn Header="Файлы" Width="90" MinWidth="50">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:ProcessingTask">
                            <Button Content="{x:Bind FilesCount}" 
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    FontSize="11" Padding="6,2" MinHeight="0" MinWidth="0"
                                    Background="Transparent" BorderThickness="0"
                                    ToolTipService.ToolTip="Список файлов"
                                    IsHitTestVisible="False"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTextColumn Header="RomFS" Binding="{Binding HasRomFs}" IsReadOnly="True" Width="90" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                <controls:DataGridTextColumn Header="ExeFS" Binding="{Binding HasExeFs}" IsReadOnly="True" Width="90" MinWidth="50" ElementStyle="{StaticResource CenterAlignedCell}"/>
                <controls:DataGridTemplateColumn Header="Статус" Width="150" MinWidth="50">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:ProcessingTask">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6" VerticalAlignment="Center" Margin="4,0">
                                <Border Background="{Binding StatusColor}" CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Foreground="White" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTemplateColumn Header="Выполнение" Width="160" MinWidth="50">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:ProcessingTask">
                            <Grid Margin="8,0" VerticalAlignment="Center">
                                <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100" VerticalAlignment="Center" Foreground="{Binding StatusColor}" Height="6" CornerRadius="3"/>
                                <TextBlock Text="{Binding Speed}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-16,4,0" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontWeight="SemiBold"/>
                            </Grid>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
            </controls:DataGrid.Columns>

            <!-- Детали задачи (Лог и инфо) -->
            <controls:DataGrid.RowDetailsTemplate>
                <DataTemplate x:DataType="models:ProcessingTask">
                    <Border Background="#1A1A1A" Padding="15" Margin="0,0,0,10" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Левая колонка: Основная информация -->
                            <StackPanel Grid.Column="0" Spacing="5" Margin="0,0,10,0">
                                <TextBlock Text="Детальная информация:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                                <Grid ColumnSpacing="10" RowSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Входная папка:" Foreground="#00CCFF"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind InputFolders}" Foreground="LightGray" TextWrapping="Wrap"/>
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Выходная папка:" Foreground="#00CCFF"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind OutputFolder}" Foreground="LightGray" TextWrapping="Wrap"/>
                                    
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Имя файла:" Foreground="#00CCFF"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind OutputFileName}" Foreground="#00FFCC" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>

                            <!-- Правая колонка: Лог -->
                            <StackPanel Grid.Column="1" Spacing="5">
                                <TextBlock Text="Журнал сборки:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                                <ScrollViewer Height="150" Background="#111" CornerRadius="4" Padding="5">
                                    <TextBlock Text="{x:Bind LogDetails, Mode=OneWay}" 
                                               Foreground="#10B981" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </controls:DataGrid.RowDetailsTemplate>

        </controls:DataGrid>
    </Grid>
</Page>
